#include <iostream>
using namespace std;

int stairs(int n) {
    if (n == 1)
        return 1;

    if (n == 2)
        return 2;
    int ans = stairs(n - 1) + stairs(n - 2);

    return ans;
}

int main() {
    int n;

    cout << "Enter number of stairs: ";
    cin >> n;

    cout << "Total ways = " << stairs(n);

    return 0;
}
