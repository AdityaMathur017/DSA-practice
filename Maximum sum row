#include<iostream>
using namespace std;
int rowIndex = 0;
int main(){
    int arr[100][100];
    int rows;
    int cols;
    cin>>rows>>cols;
    for(int i = 0; i < rows; i++)
{
    for(int j = 0; j < cols; j++)
    {
        cin>>arr[i][j];
    }
}
int max;

for(int i = 0; i < rows; i++)
{
    int sum = 0;

    for(int j = 0; j < cols; j++)
    {
        sum += arr[i][j];
    }

    cout << sum << endl;

    if(i == 0)
{
    max = sum;
}

if( sum > max){
    max = sum;
    rowIndex = i;
}




}


cout<<"maximum sum is"<<max<< "in row"<< rowIndex;
return 0;



}
