#include<iostream>
using namespace std;

void reverseArray(int n, int arr[]) {
    int start = 0;
    int end = n - 1;

    while(start < end) {
        swap(arr[start], arr[end]);
        start++;
        end--;
    }
}

int main() {
    int size;
    cin >> size;
    int arr[100];

    for(int i = 0; i < size; i++) {
        cin >> arr[i];
    }
    reverseArray(size, arr);
    cout << "Reversed Array: ";

    for(int i = 0; i < size; i++) {
        cout << arr[i] << " ";
    }

    return 0;
}
