#include<iostream>
using namespace std;

void swapElement(int n, int arry[]){
    for(int i = 0; i < n - 1; i += 2){
        swap(arry[i], arry[i + 1]);
    }
}

int main(){
    int size;
    cin >> size;

    int arr[100];

    for(int i = 0; i < size; i++){
        cin >> arr[i];
    }
    swapElement(size, arr);
    for(int i = 0; i < size; i++){
        cout << arr[i] << " ";
    }

    return 0;
}
