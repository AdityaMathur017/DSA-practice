#include<iostream>
using namespace std;

int elementDuplicate(int n, int arr[]){
    for(int i = 0; i < n; i++){
        for(int j = i + 1; j < n; j++){
            if(arr[i] == arr[j]){
                return arr[i];
            }
        }
    }
    return -1;
}

int main(){
    int size;
    cin >> size;
    int arr[100];
    for(int i = 0; i < size; i++){
        cin >> arr[i];
    }

    cout << "The duplicate number is "
         << elementDuplicate(size, arr);

    return 0;
}
